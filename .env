# API Configuration - Priority: Gemini > OpenAI > HuggingFace

# 2. OPENAI API (Secondary)
OPENAI_API_KEY=
MODEL_NAME_OPENAI=gpt-4o-mini

# 3. HUGGINGFACE TOKEN (Fallback)
HF_TOKEN=
MODEL_NAME_HF=Qwen/Qwen2.5-72B-Instruct

# SETUP INSTRUCTIONS:
# For Gemini: 
#   1. Get key from https://aistudio.google.com/app/apikeys
#   2. Set GEMINI_API_KEY=your-gemini-key-here
#   3. Optionally set MODEL_NAME=gemini-1.5-flash (faster, cheaper) or gemini-1.5-pro (smarter)
#
# For OpenAI:
#   1. Get key from https://platform.openai.com/api/keys
#   2. Set OPENAI_API_KEY=sk-your-key-here
#   3. Optionally set MODEL_NAME=gpt-4o-mini (default) or gpt-4o (smarter)
#
# For HuggingFace:
#   1. Keep HF_TOKEN set if no Gemini or OpenAI key
#   2. This will use the Inference API (may have rate limits)
